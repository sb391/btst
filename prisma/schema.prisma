generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model InvoiceUploadedFile {
  id               String        @id @default(cuid())
  originalFileName String
  mimeType         String
  sizeBytes        Int
  storagePath      String
  checksum         String
  pageCount        Int?
  previewKind      String?
  uploadStatus     String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  review           InvoiceReview?
}

model InvoiceReview {
  id                        String                  @id @default(cuid())
  reviewNumber              String                  @unique
  uploadedFileId            String                  @unique
  uploadedFile              InvoiceUploadedFile     @relation(fields: [uploadedFileId], references: [id], onDelete: Cascade)
  processingStatus          String
  ocrProviderKey            String
  ocrProviderMode           String?
  extractionVersion         String?
  rawOcrText                String?
  rawOcrPayload             String?
  normalizedPayload         String?
  summaryInvoiceNumber      String?
  summaryInvoiceDate        DateTime?
  summarySupplierName       String?
  summaryBuyerName          String?
  summaryTotalAmount        Float?
  extractionConfidenceScore Float                   @default(0)
  completenessScore         Float                   @default(0)
  consistencyScore          Float                   @default(0)
  riskScore                 Float                   @default(0)
  overallHealthStatus       String
  analystRecommendation     String
  analystDecision           String?
  analystDecisionReason     String?
  extractedFields           InvoiceExtractedField[]
  lineItems                 InvoiceExtractedLineItem[]
  validationResults         InvoiceValidationResult[]
  scores                    InvoiceReviewScore[]
  aiReview                  InvoiceAiReview?
  analystNotes              InvoiceReviewNote[]
  auditLogs                 InvoiceReviewAuditLog[]
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
}

model InvoiceExtractedField {
  id             String   @id @default(cuid())
  reviewId       String
  review         InvoiceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  section        String
  fieldKey       String
  label          String
  valueText      String?
  confidence     Float    @default(0)
  isPresent      Boolean  @default(true)
  pageNumber     Int?
  source         String?
  rawTextSnippet String?
  createdAt      DateTime @default(now())
}

model InvoiceExtractedLineItem {
  id             String   @id @default(cuid())
  reviewId       String
  review         InvoiceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  lineNumber     Int
  description    String?
  quantity       Float?
  unitPrice      Float?
  taxableValue   Float?
  lineAmount     Float?
  hsnSac         String?
  confidence     Float    @default(0)
  rawTextSnippet String?
  createdAt      DateTime @default(now())
}

model InvoiceValidationResult {
  id             String   @id @default(cuid())
  reviewId       String
  review         InvoiceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  checkName      String
  status         String
  severity       String
  message        String
  impactedFields String?
  evidence       String?
  createdAt      DateTime @default(now())
}

model InvoiceReviewScore {
  id         String   @id @default(cuid())
  reviewId   String
  review     InvoiceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  scoreKey   String
  label      String
  score      Float
  rationale  String?
  metadata   String?
  createdAt  DateTime @default(now())
}

model InvoiceAiReview {
  id                String   @id @default(cuid())
  reviewId          String   @unique
  review            InvoiceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  provider          String
  model             String
  promptVersion     String
  visibleFacts      String?
  missingFields     String?
  suspiciousSignals String?
  uncertaintyNotes  String?
  internalCoherence String?
  summary           String
  recommendedAction String
  rawResponse       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model InvoiceReviewNote {
  id         String   @id @default(cuid())
  reviewId   String
  review     InvoiceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  authorName String?
  body       String
  createdAt  DateTime @default(now())
}

model InvoiceReviewAuditLog {
  id         String   @id @default(cuid())
  reviewId   String
  review     InvoiceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String
  metadata   String?
  createdAt  DateTime @default(now())
}
